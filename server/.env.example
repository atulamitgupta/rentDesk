# =============================================================
# Cloud Bass Rent Management — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# =============================================================

# ── Database (PostgreSQL) ───────────────────────────────────
# Get this from: https://neon.tech  OR  https://supabase.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rentdesk?schema=public"

# ── JWT Authentication ──────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_32+_CHAR_SECRET"
JWT_EXPIRES_IN="7d"

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS — Set to your frontend URL ─────────────────────────
CLIENT_URL=http://localhost:5173

# ── WhatsApp ────────────────────────────────────────────────
# Path where whatsapp-web.js saves the session data
WWEBJS_SESSION_PATH="./.wwebjs_auth"

# ── Rent Engine ─────────────────────────────────────────────
# Day of month rent is due (default: 5th)
DUE_DAY_OF_MONTH=5
# Timezone for cron jobs (IANA format)
CRON_TIMEZONE="Asia/Kolkata"
